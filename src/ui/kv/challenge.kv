<ChallengeScreen>:
    MDBoxLayout:
        orientation: "vertical"
        padding: "16dp"
        spacing: "16dp"
        md_bg_color: app.theme_cls.bg_normal

        # Header row
        MDBoxLayout:
            size_hint_y: None
            height: "48dp"
            spacing: "8dp"

            MDLabel:
                text: f"Word {root.current_index + 1} / {root.total_words}"
                font_style: "Subtitle1"
                size_hint_x: 0.5

            MDLabel:
                text: f"[b]{root.time_remaining}s[/b]"
                markup: True
                halign: "right"
                font_style: "Subtitle1"
                size_hint_x: 0.5
                theme_text_color: "Custom"
                text_color:
                    (0.9, 0.2, 0.2, 1) if root.time_remaining <= 10 else \
                    (0.9, 0.7, 0.0, 1) if root.time_remaining <= 20 else \
                    app.theme_cls.primary_color

        # Progress bar
        MDProgressBar:
            value: (root.current_index / max(root.total_words, 1)) * 100
            size_hint_y: None
            height: "6dp"

        # Flashcard
        MDCard:
            id: prompt_card
            orientation: "vertical"
            padding: "24dp"
            spacing: "12dp"
            radius: [16,]
            elevation: 4
            size_hint_y: None
            height: "180dp"

            MDLabel:
                text: "Translate:"
                font_style: "Caption"
                halign: "center"
                adaptive_height: True

            MDLabel:
                text: root.prompt_text
                font_style: "H5"
                halign: "center"
                markup: True
                adaptive_height: True

        # Answer field
        MDTextField:
            id: answer_field
            hint_text: "Your answer…"
            mode: "rectangle"
            size_hint_y: None
            height: "56dp"
            on_text_validate: root.submit_answer()
            font_size: "18sp"

        # Submit button
        MDRaisedButton:
            text: "Submit"
            size_hint_x: 1
            height: "52dp"
            on_release: root.submit_answer()
            font_size: "16sp"

        # Feedback
        MDLabel:
            text: root.feedback_text
            markup: True
            halign: "center"
            font_style: "Subtitle1"
            theme_text_color: "Custom"
            text_color: root.result_color
            adaptive_height: True

        Widget:  # spacer
