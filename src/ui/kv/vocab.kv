<VocabScreen>:
    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Vocabulary"
            elevation: 2
            left_action_items: [["arrow-left", lambda x: setattr(app.root, 'current', 'home')]]
            right_action_items: [["plus", lambda x: root.open_add_dialog()]]

        ScrollView:
            MDList:
                id: word_list
